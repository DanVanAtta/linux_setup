# PAT (Personal Access Token) loader - Ansible managed
# Secrets are stored in GNOME Keyring via secret-tool.
# To manually add/update a token:
#   secret-tool store --label="<label>" service pat_tokens key <KEY_NAME>
{% for token in pat_token_keys %}
export {{ token.key }}=$(secret-tool lookup service pat_tokens key {{ token.key }} 2>/dev/null)
{% endfor %}

export LINODE_ACCESS_TOKEN="$LINODE_TOKEN"
export ORG_GRADLE_PROJECT_triplea_github_username=DanVanAtta
export ORG_GRADLE_PROJECT_triplea_github_access_token="${GITHUB_TOKEN}"