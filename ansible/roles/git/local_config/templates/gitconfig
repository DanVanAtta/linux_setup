[include]
        path = {{ git_user_name_config }}
[includeIf "gitdir:~/"]
        path = {{ git_gpg_key_config }}
[include]
        path = {{ git_github_credential_config }}
[core]
        editor = vi
        autocrlf = input
[merge]
        tool = meld
[push]
        default = current
[color "diff-highlight"]
        oldNormal = red bold
        oldHighlight = red bold 52
        newNormal = green bold
        newHighlight = green bold 22
[mergetool]
        keepBackup = false

